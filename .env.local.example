# ── Bibloo — Firebase Environment Variables ───────────────────────────────
# Copie este arquivo para .env.local e preencha com os valores do:
# Firebase Console → Project Settings → Your apps → bibloo-web → SDK setup
#
# NUNCA commite o arquivo .env.local com valores reais!

VITE_FIREBASE_API_KEY=AIzaSy_COLE_AQUI
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto-id
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:cole_aqui
